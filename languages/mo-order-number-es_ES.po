#. translators: %s: enlace a la página de gestión de plugins
#: mo-order-number.php:49
#, php-format
msgid "MO Order Number vyžaduje aktivní plugin WooCommerce. %s"
msgstr "MO Order Number requiere que WooCommerce esté activo. %s"

#: mo-order-number.php:51
msgid "Správa pluginů"
msgstr "Gestión de plugins"

#: includes/class-mon-admin.php:21
msgid "YYYY + pořadí v roce  (např. 2026000042)"
msgstr "YYYY + secuencia en el año  (p. ej. 2026000042)"

#: includes/class-mon-admin.php:26
msgid "YYYYMM + pořadí v měsíci  (např. 2026040042)"
msgstr "YYYYMM + secuencia en el mes  (p. ej. 2026040042)"

#: includes/class-mon-admin.php:31
msgid "Globální pořadové číslo  (např. 0000000042)"
msgstr "Número de secuencia global  (p. ej. 0000000042)"

#: includes/class-mon-admin.php:51 includes/class-mon-admin.php:52
#: includes/class-mon-admin.php:118
msgid "Číslování objednávek"
msgstr "Numeración de pedidos"

#: includes/class-mon-admin.php:65 includes/class-mon-admin.php:316
#: includes/class-mon-admin.php:358
msgid "Nedostatečná oprávnění."
msgstr "Permisos insuficientes."

#. translators: %d: año
#: includes/class-mon-admin.php:79
#, php-format
msgid "Roční %d"
msgstr "Anual %d"

#. translators: 1: año, 2: mes
#: includes/class-mon-admin.php:86
#, php-format
msgid "Měsíční %1$d/%2$02d"
msgstr "Mensual %1$d/%2$02d"

#: includes/class-mon-admin.php:91
msgid "Globální"
msgstr "Global"

#: includes/class-mon-admin.php:131
msgid "Formát čísla objednávky"
msgstr "Formato del número de pedido"

#: includes/class-mon-admin.php:133
msgid "Stávající objednávky si ponechají původní čísla. Nový formát se uplatní od příští vytvořené objednávky."
msgstr "Los pedidos existentes conservarán sus números originales. El nuevo formato se aplicará desde el próximo pedido creado."

#: includes/class-mon-admin.php:139
msgid "Předvolba"
msgstr "Predefinido"

#: includes/class-mon-admin.php:143
msgid "— vlastní —"
msgstr "— personalizado —"

#: includes/class-mon-admin.php:154
msgid "Vzorec (sprintf)"
msgstr "Patrón (sprintf)"

#: includes/class-mon-admin.php:161
#, php-format
msgid "Poziční argumenty: %1$s = rok (YYYY), %2$s = měsíc (MM), %3$s = pořadové číslo."
msgstr "Argumentos posicionales: %1$s = año (YYYY), %2$s = mes (MM), %3$s = número de secuencia."

#: includes/class-mon-admin.php:162
#, php-format
msgid "Příklady: %1$04d%3$06d · %1$04d%2$02d%3$04d · %3$010d"
msgstr "Ejemplos: %1$04d%3$06d · %1$04d%2$02d%3$04d · %3$010d"

#: includes/class-mon-admin.php:165
msgid "Náhled:"
msgstr "Vista previa:"

#: includes/class-mon-admin.php:168
msgid "⚠ Neplatný vzorec"
msgstr "⚠ Patrón no válido"

#: includes/class-mon-admin.php:175
msgid "Perioda čítače"
msgstr "Período del contador"

#: includes/class-mon-admin.php:180
msgid "Roční – reset každý rok"
msgstr "Anual – se reinicia cada año"

#: includes/class-mon-admin.php:183
msgid "Měsíční – reset každý měsíc"
msgstr "Mensual – se reinicia cada mes"

#: includes/class-mon-admin.php:186
msgid "Globální – nikdy se neresetuje"
msgstr "Global – nunca se reinicia"

#: includes/class-mon-admin.php:190
msgid "Určuje, kdy se pořadové číslo vrátí na 1. Musí odpovídat použitému vzorci."
msgstr "Determina cuándo se reinicia el número de secuencia a 1. Debe coincidir con el patrón utilizado."

#: includes/class-mon-admin.php:196
msgid "Uložit změny"
msgstr "Guardar cambios"

#: includes/class-mon-admin.php:202
msgid "Aktuální stav čítačů"
msgstr "Estado actual de los contadores"

#: includes/class-mon-admin.php:204
msgid "Reset nastaví čítač na 0. Příští objednávka dostane pořadové číslo 1."
msgstr "El reinicio establece el contador en 0. El próximo pedido recibirá el número de secuencia 1."

#: includes/class-mon-admin.php:210
msgid "Čítač"
msgstr "Contador"

#: includes/class-mon-admin.php:211
msgid "Hodnota"
msgstr "Valor"

#: includes/class-mon-admin.php:292
msgid "Opravdu resetovat tento čítač na 0? Příští objednávka dostane pořadové číslo 1. Tuto akci nelze vrátit."
msgstr "¿Está seguro de que desea reiniciar este contador a 0? El próximo pedido recibirá el número de secuencia 1. Esta acción no se puede deshacer."

#: includes/class-mon-admin.php:304
msgid "Resetovat"
msgstr "Reiniciar"

#: includes/class-mon-admin.php:338
msgid "Neplatný vzorec. Nastavení nebylo uloženo."
msgstr "Patrón no válido. La configuración no se ha guardado."

#: includes/class-mon-admin.php:343
msgid "Nastavení bylo uloženo."
msgstr "Configuración guardada."

#. translators: %s: identificador del contador (p. ej. y2026, m202604, global)
#: includes/class-mon-admin.php:367
#, php-format
msgid "Čítač „%s\" byl resetován na 0."
msgstr "El contador \"%s\" ha sido reiniciado a 0."
